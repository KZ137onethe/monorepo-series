{
  "name": "monorepo-series",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18",
    "pnpm": ">=9.15.2",
    "rimraf": ">=6.0.0",
    "concurrently": ">=9.0.0",
    "nodemon": ">=3.0.0"
  },
	"packageManager": "pnpm@10.15.1",
  "scripts": {
    "clean": "rimraf **/node_modules --glob",
    "reinstall": "pnpm run clean && pnpm install",
    "play-webpack-1:dev": "pnpm -F @monorepo-series/play-webpack-1 dev",
    "play-webpack-2:dev": "pnpm -F @monorepo-series/play-webpack-2 dev",
    "web:dev": "pnpm -F @monorepo-series/web dev",
		"server:dev": "pnpm -F @monorepo-series/server dev",
		"dev": "turbo dev",
		"build": "turbo build"
  },
  "dependencies": {
    "es-toolkit": "catalog:",
    "html-webpack-plugin": "catalog:",
    "vue": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:",
    "webpack-dev-server": "catalog:"
  },
  "devDependencies": {
    "@changesets/changelog-git": "catalog:",
    "@changesets/cli": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "concurrently": "catalog:",
    "turbo": "catalog:",
    "vite": "catalog:"
  }
}